# ── Foundry hosted agent — insurance claims orchestrator ──
# Copy to `.env` for local dev. Foundry injects these at runtime in production
# (load_dotenv(override=False) lets runtime values win over this file).

# === Orchestrator ===
USE_MAF_ORCHESTRATOR=true
OPENAI_REASONING_EFFORT=low
AGENT_ID=insurance-claims-orchestrator

# === Model access — choose ONE path ===
# Path A (default): direct Azure OpenAI with managed identity / az login (no secrets).
USE_APIM_GATEWAY=false
AZURE_OPENAI_ENDPOINT=https://ins-ai-demo-aoai-jii435hjlwyyc.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-mini
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Path B: route through the APIM AI Gateway (content safety, token limits, audit).
# Preserves the governance story but requires a subscription key at runtime.
# USE_APIM_GATEWAY=true
# APIM_GATEWAY_URL=https://<apim-name>.azure-api.net/<path>
# APIM_SUBSCRIPTION_KEY=__set_at_runtime__do_not_commit__

# === Foundry hosting runtime (injected by Foundry; set for local parity) ===
# FOUNDRY_PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>
# FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-5.4-mini

# === Observability (optional — enables App Insights tracing) ===
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...

# === Server ===
PORT=8088
LOG_LEVEL=INFO
