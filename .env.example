# Environment variables for the Insurance AI Demo
# Copy this file to .env and fill in the values after deploying infrastructure

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://<your-openai-name>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-mini
AZURE_OPENAI_VOICE_DEPLOYMENT=gpt-realtime-mini

# gpt-5.4-mini es un modelo razonador. Por defecto consume reasoning tokens
# antes de cada respuesta, lo que añade 4-10 s de latencia por agente.
# Valores: minimal | low (default demo) | medium (default OpenAI) | high
# - "minimal" es el más rápido pero el modelo apenas razona y todo cae a
#   human_review (sin contraste de decisiones).
# - "low" es el equilibrio que usamos: rápido pero distingue approve / reject
#   / review correctamente.
OPENAI_REASONING_EFFORT=low

# Azure AI Services (Content Understanding, Speech, Translator, etc.)
AZURE_AI_SERVICES_ENDPOINT=https://<your-ai-services-name>.cognitiveservices.azure.com/

# Microsoft Agent Framework — orquestador moderno con streaming token-level
# Si está activo, intenta MAF. Si MAF falla, cae automáticamente al orquestador legacy.
USE_MAF_ORCHESTRATOR=false

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# ── Cosmos DB (persistencia de siniestros) ──────────────────────────────────
# Si COSMOS_ENDPOINT está vacío, el backend cae en modo en-memoria (no-op).
# La autenticación es AAD-only (sin keys) → se usa DefaultAzureCredential.
# Asegúrate de tener el rol "Cosmos DB Built-in Data Contributor" sobre la cuenta.
COSMOS_ENDPOINT=https://<your-cosmos-name>.documents.azure.com:443/
COSMOS_DATABASE=insurance-claims
COSMOS_CONTAINER=claims

# ── Microsoft Entra ID (separación cliente/operario) ────────────────────────
# AUTH_ENABLED=false (default): demo abierta, sin login.
# AUTH_ENABLED=true: backend valida JWT contra el tenant; frontend pide login.
# Roles esperados: Customer.Submit, Operator.Review.
AUTH_ENABLED=false
AUTH_TENANT_ID=<your-tenant-id>
AUTH_CLIENT_ID=<your-app-registration-client-id>

